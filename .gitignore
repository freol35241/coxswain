# Cargo builds here only when CARGO_TARGET_DIR is unset; the devcontainer
# points it at a volume outside the tree.
/target
**/*.rs.bk

# crates/coxswain-xprofile-target is excluded from the root workspace (its
# own Cargo.lock, see its Cargo.toml), so `/target` above does not cover its
# build output; it gets its own target dir at build time.
crates/coxswain-xprofile-target/target/

# Compiled manifest blobs are commissioning artifacts, not source.
*.cxmanifest
